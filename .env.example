# ============================================================
# MCP-Agentic RAG Backend — 环境变量模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- 应用 ---
APP_NAME="MCP-Agentic RAG Backend"
APP_VERSION="0.1.0"
APP_ENV=development
APP_DEBUG=true

# --- 数据库 (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_rag

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- 模型服务 (OpenAI-compatible API) ---
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b

# --- Embedding 服务 ---
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=bge-m3

# --- Reranker 服务 ---
RERANKER_BASE_URL=http://localhost:8001/v1
RERANKER_API_KEY=not-needed
RERANKER_MODEL=bge-reranker-base

# --- 向量数据库 ---
CHROMA_PERSIST_DIR=./storage/chroma

# --- 文件存储 ---
STORAGE_DIR=./storage/uploads
MAX_UPLOAD_SIZE_MB=50

# --- 日志 ---
LOG_LEVEL=INFO
LOG_FILE=./storage/logs/app.log
