# ============================================================
# MCP-Agentic RAG Backend — 环境变量模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- 应用 ---
APP_NAME="MCP-Agentic RAG Backend"
APP_VERSION="0.1.0"
APP_ENV=development
APP_DEBUG=true

# --- 数据库 ---
# 本地开发推荐 SQLite：
DATABASE_URL=sqlite+aiosqlite:///storage/agentic_rag.db
# 生产环境使用 PostgreSQL：
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_rag

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================================
# LLM 模型配置（三选一）
# ============================================================

# 方案 A：阿里云百炼 / DashScope (Qwen 系列)
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-your-dashscope-api-key-here
LLM_MODEL=qwen-plus
# 备选: qwen-turbo(更快/便宜) / qwen-max(更强) / qwen-long(长文本)

# 方案 B：本地 Ollama（开发测试）
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:7b

# 方案 C：其他 OpenAI-compatible API
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-key
# LLM_MODEL=gpt-4o

# ============================================================
# Embedding 模型配置
# ============================================================

# DashScope Embedding（配合 Qwen 方案）
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=sk-your-dashscope-api-key-here
EMBEDDING_MODEL=text-embedding-v4

# 本地 Ollama Embedding
# EMBEDDING_BASE_URL=http://localhost:11434/v1
# EMBEDDING_API_KEY=ollama
# EMBEDDING_MODEL=bge-m3

# ============================================================
# Reranker 配置
# ============================================================

# DashScope 目前无标准 Reranker API，开发环境使用 FakeReranker
RERANKER_BASE_URL=http://localhost:8001/v1
RERANKER_API_KEY=not-needed
RERANKER_MODEL=bge-reranker-base

# --- 向量数据库 ---
CHROMA_PERSIST_DIR=./storage/chroma

# --- 文件存储 ---
STORAGE_DIR=./storage/uploads
MAX_UPLOAD_SIZE_MB=50

# --- 日志 ---
LOG_LEVEL=INFO
LOG_FILE=./storage/logs/app.log
